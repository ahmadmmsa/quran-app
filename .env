# Backend config (DB, secrets, app, embedding) now lives in quran.conf.
# This file is only for docker-compose interpolation and local npm dev.

# Local Dev Ports (for npm run dev)
APP_PORT=8060
VITE_PORT=5173
VITE_PROXY_TARGET=http://127.0.0.1:8060

# Docker external port (host side) for docker compose up
DOCKER_PORT=8000
